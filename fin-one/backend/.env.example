# Server
PORT=5000
NODE_ENV=development

# MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=fin_one

# Auth
JWT_SECRET=replace_this_with_a_long_random_string
JWT_EXPIRES_IN=7d

# CORS - comma separated list of allowed origins (your frontend URL)
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:5500
